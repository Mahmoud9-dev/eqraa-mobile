{
  "$schema": "https://raw.githubusercontent.com/nicegoodthings/tauri/main/crates/tauri-utils/schema.json",
  "identifier": "mobile",
  "description": "Capability for the mobile app — sandboxed filesystem scope for Android",
  "platforms": ["android", "iOS"],
  "permissions": [
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:path:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-copy-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**",
        "$APPCACHE/**",
        "$APPDATALOCAL/**"
      ]
    }
  ]
}
